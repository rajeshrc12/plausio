generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VideoVisibility {
  PUBLIC
  PRIVATE
}

enum VideoStatus {
  INIT
  PROCESSING
  UPLOADED
  FAILED
}

model Channel {
  id          Int    @id @default(autoincrement())
  handle      String @unique
  email       String @unique
  name        String
  description String
  country     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos Video[]
}

model Video {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  type        String

  visibility VideoVisibility? @default(PUBLIC)
  status     VideoStatus?     @default(INIT)

  likes    Int? @default(0)
  dislikes Int? @default(0)
  views    Int? @default(0)

  duration Int
  size     Int
  name     String

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  channelId Int
  channel   Channel @relation(fields: [channelId], references: [id])
}
